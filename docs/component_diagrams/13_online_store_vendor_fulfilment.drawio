        <mxCell id="pr" value="&lt;b&gt;1. Purchase Request&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Requester places online order&lt;br&gt;line items, cost centre, vendor, amount&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;fontSize=9;arcSize=10;" vertex="1" parent="1">
