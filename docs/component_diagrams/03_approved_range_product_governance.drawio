<mxfile host="app.diagrams.net" modified="2026-02-19T00:00:00.000Z" agent="cursor" version="24.0.0" type="device">
  <diagram id="approved-range" name="Approved Range — Product Governance Flow">
    <mxGraphModel dx="1800" dy="1500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="3 — Approved Range: Product Governance Flow" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="600" height="35" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Products are created in Postgres but only enter the graph (Neo4j) when added to an Approved Range — the governance filter for product visibility" style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="120" y="42" width="760" height="22" as="geometry" />
        </mxCell>

        <!-- ========== STEP 1: PRODUCT CREATION ========== -->
        <mxCell id="s1_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="85" width="400" height="120" as="geometry" />
        </mxCell>
        <mxCell id="s1_lbl" value="Step 1: Product Created in Catalog" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="100" y="88" width="320" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s1_api" value="&lt;b&gt;POST /catalog/products&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Admin creates a product&lt;br&gt;(passes RBAC + Policy gates)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565C0;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="115" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s1_pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;INSERT INTO products&lt;br&gt;+ outbox: product.created&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#ffffff;strokeColor=#0078D4;fontSize=9;size=8;" vertex="1" parent="1">
          <mxGeometry x="310" y="112" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e_s1" style="rounded=1;strokeColor=#1565C0;strokeWidth=2;" edge="1" parent="1" source="s1_api" target="s1_pg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Product goes to pgvector only -->
        <mxCell id="s1_vec" value="&lt;b&gt;pgvector&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Embedding generated&lt;br&gt;for semantic search&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#7B1FA2;fontColor=#ffffff;strokeColor=#7B1FA2;fontSize=9;size=8;" vertex="1" parent="1">
          <mxGeometry x="540" y="90" width="130" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e_s1v" style="rounded=1;strokeColor=#7B1FA2;strokeWidth=1.5;" edge="1" parent="1" source="s1_pg" target="s1_vec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_s1vl" value="product.created event" style="edgeLabel;html=1;fontSize=8;fontColor=#7B1FA2;" vertex="1" connectable="0" parent="e_s1v">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- NOT going to graph -->
        <mxCell id="s1_no_graph" value="&lt;font color='#C62828'&gt;&lt;b&gt;✗ Does NOT go to Neo4j&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Graph consumer ignores&lt;br&gt;product.created events&lt;/font&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="160" width="190" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e_s1ng" style="rounded=1;strokeColor=#C62828;strokeWidth=1.5;dashed=1;" edge="1" parent="1" source="s1_pg" target="s1_no_graph">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== STEP 2: APPROVED RANGE CREATED ========== -->
        <mxCell id="s2_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="240" width="670" height="110" as="geometry" />
        </mxCell>
        <mxCell id="s2_lbl" value="Step 2: Approved Range Created" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="240" y="243" width="310" height="20" as="geometry" />
        </mxCell>
        <mxCell id="s2_api" value="&lt;b&gt;POST /approved-ranges&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Create range: name, description&lt;br&gt;is_universal (true/false)&lt;br&gt;Linked to Org Units&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#E65100;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="200" height="65" as="geometry" />
        </mxCell>
        <mxCell id="s2_pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;INSERT INTO approved_ranges&lt;br&gt;+ outbox: approved_range.created&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#ffffff;strokeColor=#0078D4;fontSize=9;size=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="272" width="160" height="58" as="geometry" />
        </mxCell>
        <mxCell id="s2_neo" value="&lt;b&gt;Neo4j&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;MERGE (ar:ApprovedRange)&lt;br&gt;SET name, tenant_id, status&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#00897B;fontColor=#ffffff;strokeColor=#00897B;fontSize=9;size=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="272" width="150" height="58" as="geometry" />
        </mxCell>
        <mxCell id="e_s2a" style="rounded=1;strokeColor=#E65100;strokeWidth=2;" edge="1" parent="1" source="s2_api" target="s2_pg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_s2b" style="rounded=1;strokeColor=#00897B;strokeWidth=2;" edge="1" parent="1" source="s2_pg" target="s2_neo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_s2bl" value="event" style="edgeLabel;html=1;fontSize=8;fontColor=#00897B;" vertex="1" connectable="0" parent="e_s2b">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ========== STEP 3: PRODUCTS ADDED TO RANGE ========== -->
        <mxCell id="s3_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;arcSize=8;strokeWidth=3;" vertex="1" parent="1">
          <mxGeometry x="60" y="385" width="870" height="140" as="geometry" />
        </mxCell>
        <mxCell id="s3_lbl" value="Step 3: Products Added to Approved Range (THE GOVERNANCE GATE)" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="190" y="390" width="550" height="20" as="geometry" />
        </mxCell>

        <mxCell id="s3_api" value="&lt;b&gt;POST /approved-ranges&lt;br&gt;/{id}/products&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Add product IDs to range&lt;br&gt;Policy: approved_range.add_products&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="420" width="200" height="75" as="geometry" />
        </mxCell>

        <mxCell id="s3_pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;INSERT INTO&lt;br&gt;approved_range_products&lt;br&gt;+ outbox:&lt;br&gt;approved_range.products_added&lt;br&gt;payload: {product_ids: [...] }&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#ffffff;strokeColor=#0078D4;fontSize=8;size=8;" vertex="1" parent="1">
          <mxGeometry x="340" y="415" width="190" height="90" as="geometry" />
        </mxCell>

        <mxCell id="s3_neo" value="&lt;b&gt;Neo4j — Graph Consumer&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;For each product_id:&lt;br&gt;MERGE (p:Product {product_id})&lt;br&gt;MERGE (ar:ApprovedRange {id})&lt;br&gt;MERGE (ar)-[:INCLUDES]-&gt;(p)&lt;br&gt;&lt;b&gt;Product NOW enters the graph!&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;arcSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="600" y="415" width="240" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e_s3a" style="rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="s3_api" target="s3_pg">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_s3b" style="rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="s3_pg" target="s3_neo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_s3bl" value="products_added event" style="edgeLabel;html=1;fontSize=8;fontColor=#2E7D32;fontStyle=1;" vertex="1" connectable="0" parent="e_s3b">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ========== RESULTING GRAPH STRUCTURE ========== -->
        <mxCell id="grp_graph" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="870" height="180" as="geometry" />
        </mxCell>
        <mxCell id="graph_title" value="Resulting Neo4j Graph Structure" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#00897B;" vertex="1" parent="1">
          <mxGeometry x="330" y="565" width="340" height="20" as="geometry" />
        </mxCell>

        <!-- Graph nodes -->
        <mxCell id="gn_tenant" value="&lt;b&gt;(:Tenant)&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="600" width="100" height="45" as="geometry" />
        </mxCell>
        <mxCell id="gn_ou" value="&lt;b&gt;(:OrgUnit)&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FF9800;fontColor=#ffffff;strokeColor=#FF9800;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="270" y="600" width="110" height="45" as="geometry" />
        </mxCell>
        <mxCell id="gn_ar" value="&lt;b&gt;(:ApprovedRange)&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#2E7D32;fontColor=#ffffff;strokeColor=#2E7D32;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="470" y="600" width="140" height="45" as="geometry" />
        </mxCell>
        <mxCell id="gn_p1" value="&lt;b&gt;(:Product)&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:8px'&gt;Approved&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#4CAF50;fontColor=#ffffff;strokeColor=#4CAF50;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="590" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="gn_p2" value="&lt;b&gt;(:Product)&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:8px'&gt;Approved&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#4CAF50;fontColor=#ffffff;strokeColor=#4CAF50;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="650" width="100" height="50" as="geometry" />
        </mxCell>

        <!-- Graph edges -->
        <mxCell id="ge1" style="rounded=1;strokeColor=#FF9800;strokeWidth=1.5;" edge="1" parent="1" source="gn_tenant" target="gn_ou">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ge1l" value=":HAS_UNIT" style="edgeLabel;html=1;fontSize=8;fontColor=#FF9800;" vertex="1" connectable="0" parent="ge1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="ge2" style="rounded=1;strokeColor=#2E7D32;strokeWidth=1.5;" edge="1" parent="1" source="gn_ou" target="gn_ar">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ge2l" value=":USES_RANGE" style="edgeLabel;html=1;fontSize=8;fontColor=#2E7D32;" vertex="1" connectable="0" parent="ge2">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="ge3" style="rounded=1;strokeColor=#4CAF50;strokeWidth=2;" edge="1" parent="1" source="gn_ar" target="gn_p1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ge3l" value=":INCLUDES" style="edgeLabel;html=1;fontSize=8;fontColor=#4CAF50;fontStyle=1;" vertex="1" connectable="0" parent="ge3">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="ge4" style="rounded=1;strokeColor=#4CAF50;strokeWidth=2;" edge="1" parent="1" source="gn_ar" target="gn_p2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Unapproved product (not in graph) -->
        <mxCell id="gn_unap" value="&lt;font color='#999'&gt;&lt;b&gt;Product X&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:8px'&gt;NOT in any range&lt;br&gt;= NOT in graph&lt;/font&gt;&lt;/font&gt;" style="ellipse;whiteSpace=wrap;html=1;fillColor=#EEEEEE;strokeColor=#BDBDBD;fontSize=10;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="830" y="610" width="100" height="55" as="geometry" />
        </mxCell>

        <!-- ========== VISIBILITY RULE ========== -->
        <mxCell id="grp_rule" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;arcSize=8;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="770" width="870" height="100" as="geometry" />
        </mxCell>
        <mxCell id="rule_title" value="Governance Rule: Who Can See / Order Which Products?" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="240" y="775" width="520" height="20" as="geometry" />
        </mxCell>
        <mxCell id="rule_flow" value="&lt;font style='font-size:10px'&gt;&lt;b&gt;User&lt;/b&gt; belongs to &lt;b&gt;OrgUnit&lt;/b&gt; → OrgUnit linked to &lt;b&gt;ApprovedRange&lt;/b&gt; → Range INCLUDES specific &lt;b&gt;Products&lt;/b&gt;&lt;br&gt;&lt;br&gt;If a product is NOT in any approved range linked to the user's org unit → &lt;b&gt;user cannot see or order it&lt;/b&gt;&lt;br&gt;Universal ranges (is_universal=true) apply to &lt;b&gt;all org units&lt;/b&gt; in the tenant&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="80" y="800" width="830" height="60" as="geometry" />
        </mxCell>

        <!-- Policy context enrichment note -->
        <mxCell id="ctx_note" value="&lt;font style='font-size:9px'&gt;&lt;b&gt;Policy Engine Context Enricher&lt;/b&gt; queries this chain to build&lt;br&gt;&lt;b&gt;approved_product_ids[]&lt;/b&gt; for every policy evaluation.&lt;br&gt;The &lt;b&gt;approved_product_only&lt;/b&gt; policy rule checks if the requested&lt;br&gt;product_id is in this list — deny if not.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="890" width="420" height="65" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
