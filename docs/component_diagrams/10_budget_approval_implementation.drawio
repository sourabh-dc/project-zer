        </mxCell>
        <mxCell id="prov_budget" value="&lt;b&gt;Budget Module&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Financial calendars · Company budget&lt;br&gt;Cost-centre budgets (mixed granularity)&lt;br&gt;Carry-forward · Reallocation · Bring-forward&lt;br&gt;BudgetAllocationAudit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="220" width="180" height="95" as="geometry" />
        </mxCell>
