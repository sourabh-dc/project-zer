          <mxGeometry x="300" y="220" width="180" height="95" as="geometry" />
        </mxCell>
        <mxCell id="prov_order" value="&lt;b&gt;Order / OrderRequest&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;draft → pending_approval → approved → po_issued&lt;br&gt;On submit: policy evaluate&lt;br&gt;If require_approval → call Approval Service&lt;br&gt;On approve callback: reserve budget, reduce limit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#1B5E20;fontSize=10;arcSize=10;" vertex="1" parent="1">
