<mxfile host="app.diagrams.net" modified="2026-02-19T00:00:00.000Z" agent="cursor" version="24.0.0" type="device">
  <diagram id="vector-projection" name="Vector Projection Layer &amp; Semantic Search">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="5 — Vector Projection Layer (pgvector) &amp; Semantic Search" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="600" height="35" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Product text is embedded via Azure OpenAI and stored in pgvector for governance-filtered semantic search" style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="150" y="42" width="700" height="22" as="geometry" />
        </mxCell>

        <!-- ========== EMBEDDING PIPELINE ========== -->
        <mxCell id="grp_pipeline" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;arcSize=6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="880" height="230" as="geometry" />
        </mxCell>
        <mxCell id="pipe_title" value="Embedding Pipeline (Event-Driven)" style="text;html=1;fontSize=13;fontStyle=5;align=center;verticalAlign=middle;fontColor=#7B1FA2;" vertex="1" parent="1">
          <mxGeometry x="330" y="85" width="340" height="22" as="geometry" />
        </mxCell>

        <!-- Step 1: Outbox event -->
        <mxCell id="p1_outbox" value="&lt;b&gt;Outbox Event&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;product.created&lt;br&gt;product.updated&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="140" height="55" as="geometry" />
        </mxCell>

        <!-- Step 2: Vector Consumer -->
        <mxCell id="p2_consumer" value="&lt;b&gt;Vector Consumer&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Polls outbox for product.* events&lt;br&gt;Extracts product text:&lt;br&gt;name + description + SKU + category&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7B1FA2;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="115" width="210" height="65" as="geometry" />
        </mxCell>

        <!-- Step 3: Azure OpenAI -->
        <mxCell id="p3_azure" value="&lt;b&gt;Azure OpenAI&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;text-embedding-3-small&lt;br&gt;Input: product text string&lt;br&gt;Output: 1536-dim float vector&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="550" y="115" width="200" height="65" as="geometry" />
        </mxCell>

        <!-- Step 4: pgvector upsert -->
        <mxCell id="p4_pgvec" value="&lt;b&gt;pgvector Table&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;product_embeddings&lt;br&gt;(product_id, tenant_id,&lt;br&gt; text_content, embedding VECTOR(1536),&lt;br&gt; metadata JSONB, updated_at)&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#7B1FA2;fontColor=#ffffff;strokeColor=#7B1FA2;fontSize=9;size=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="210" width="240" height="85" as="geometry" />
        </mxCell>

        <mxCell id="ep1" style="rounded=1;strokeColor=#F9A825;strokeWidth=2;" edge="1" parent="1" source="p1_outbox" target="p2_consumer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep1l" value="poll" style="edgeLabel;html=1;fontSize=8;fontColor=#F9A825;" vertex="1" connectable="0" parent="ep1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="ep2" style="rounded=1;strokeColor=#3F51B5;strokeWidth=2;" edge="1" parent="1" source="p2_consumer" target="p3_azure">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep2l" value="API call" style="edgeLabel;html=1;fontSize=8;fontColor=#3F51B5;" vertex="1" connectable="0" parent="ep2">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="ep3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;strokeWidth=2;" edge="1" parent="1" source="p3_azure" target="p4_pgvec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep3l" value="1536-dim vector" style="edgeLabel;html=1;fontSize=8;fontColor=#7B1FA2;" vertex="1" connectable="0" parent="ep3">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="ep4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;strokeWidth=2;" edge="1" parent="1" source="p2_consumer" target="p4_pgvec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ep4l" value="UPSERT" style="edgeLabel;html=1;fontSize=8;fontColor=#7B1FA2;fontStyle=1;" vertex="1" connectable="0" parent="ep4">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- Fallback note -->
        <mxCell id="fallback" value="&lt;font style='font-size:9px'&gt;&lt;b&gt;Fallback:&lt;/b&gt; If Azure OpenAI is unavailable,&lt;br&gt;a deterministic stub generates a&lt;br&gt;hash-based vector (dev/local mode)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=9;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="210" width="210" height="55" as="geometry" />
        </mxCell>

        <!-- ========== SEARCH FLOW ========== -->
        <mxCell id="grp_search" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;arcSize=6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="340" width="880" height="280" as="geometry" />
        </mxCell>
        <mxCell id="search_title" value="Semantic Search Flow (with Governance Filtering)" style="text;html=1;fontSize=13;fontStyle=5;align=center;verticalAlign=middle;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="280" y="345" width="440" height="22" as="geometry" />
        </mxCell>

        <!-- User query -->
        <mxCell id="sq_user" value="&lt;b&gt;User&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Search: &quot;blue disposable gloves&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontSize=10;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="220" height="45" as="geometry" />
        </mxCell>

        <!-- Embed query -->
        <mxCell id="sq_embed" value="&lt;b&gt;Embed Query Text&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Azure OpenAI → 1536-dim vector&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="380" width="200" height="45" as="geometry" />
        </mxCell>

        <!-- Cosine similarity -->
        <mxCell id="sq_cosine" value="&lt;b&gt;Cosine Similarity Search&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;SELECT * FROM product_embeddings&lt;br&gt;WHERE tenant_id = :tid&lt;br&gt;ORDER BY embedding &amp;lt;=&amp;gt; :query_vec&lt;br&gt;LIMIT :top_k&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#7B1FA2;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="250" height="75" as="geometry" />
        </mxCell>

        <!-- Governance filter -->
        <mxCell id="sq_gov" value="&lt;b&gt;Governance Filter&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Results filtered by user's&lt;br&gt;&lt;b&gt;approved_product_ids[]&lt;/b&gt;&lt;br&gt;(from Approved Ranges linked&lt;br&gt;to user's Org Unit)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="460" width="210" height="75" as="geometry" />
        </mxCell>

        <!-- Results -->
        <mxCell id="sq_results" value="&lt;b&gt;Governance-Filtered Results&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Top-K products ranked by&lt;br&gt;semantic similarity&lt;br&gt;Only products user is authorized&lt;br&gt;to see / order&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="460" width="210" height="75" as="geometry" />
        </mxCell>

        <mxCell id="es1" style="rounded=1;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="sq_user" target="sq_embed">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="es2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;strokeWidth=2;" edge="1" parent="1" source="sq_embed" target="sq_cosine">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="es3" style="rounded=1;strokeColor=#C62828;strokeWidth=2;" edge="1" parent="1" source="sq_cosine" target="sq_gov">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="es3l" value="filter" style="edgeLabel;html=1;fontSize=8;fontColor=#C62828;fontStyle=1;" vertex="1" connectable="0" parent="es3">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="es4" style="rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="sq_gov" target="sq_results">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== KEY PROPERTIES ========== -->
        <mxCell id="grp_props" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="650" width="880" height="80" as="geometry" />
        </mxCell>
        <mxCell id="props_title" value="Key Properties" style="text;html=1;fontSize=11;fontStyle=5;align=center;verticalAlign=middle;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="400" y="653" width="200" height="18" as="geometry" />
        </mxCell>
        <mxCell id="kp1" value="&lt;font style='font-size:9px'&gt;• &lt;b&gt;All products&lt;/b&gt; get embedded (unlike graph, which only gets approved ones)&lt;br&gt;• &lt;b&gt;Governance filtering&lt;/b&gt; happens at search time, not at embedding time&lt;br&gt;• &lt;b&gt;Tenant-scoped&lt;/b&gt; — queries always filter by tenant_id&lt;br&gt;• &lt;b&gt;Rebuildable&lt;/b&gt; — re-process all product.* events from outbox to regenerate all embeddings&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="674" width="840" height="50" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
