<mxfile host="app.diagrams.net" modified="2026-02-19T00:00:00.000Z" agent="cursor" version="24.0.0" type="device">
  <diagram id="graph-projection" name="Graph Projection Layer (Neo4j)">
    <mxGraphModel dx="2000" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="4 — Graph Projection Layer (Neo4j)" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="500" height="35" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="All governance entities projected from outbox events into a graph topology. Products only enter via Approved Ranges." style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="200" y="42" width="700" height="22" as="geometry" />
        </mxCell>

        <!-- ========== DATA FLOW: Postgres → Outbox → Graph Consumer → Neo4j ========== -->
        <mxCell id="pg" value="&lt;b&gt;PostgreSQL&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Source of Truth&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#0078D4;fontColor=#ffffff;strokeColor=#0078D4;fontSize=10;size=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="outbox" value="&lt;b&gt;outbox_events&lt;/b&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;size=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="85" width="120" height="45" as="geometry" />
        </mxCell>
        <mxCell id="consumer" value="&lt;b&gt;Graph Consumer&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Polls events, routes&lt;br&gt;to entity handlers&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="neo4j" value="&lt;b&gt;Neo4j&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Graph Database&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#00897B;fontColor=#ffffff;strokeColor=#00897B;fontSize=10;size=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="80" width="120" height="55" as="geometry" />
        </mxCell>

        <mxCell id="ef1" style="rounded=1;strokeColor=#F9A825;strokeWidth=2;" edge="1" parent="1" source="pg" target="outbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ef2" style="rounded=1;strokeColor=#00897B;strokeWidth=2;" edge="1" parent="1" source="outbox" target="consumer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ef2l" value="poll" style="edgeLabel;html=1;fontSize=8;fontColor=#00897B;" vertex="1" connectable="0" parent="ef2">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="ef3" style="rounded=1;strokeColor=#00897B;strokeWidth=2;" edge="1" parent="1" source="consumer" target="neo4j">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ef3l" value="Cypher MERGE" style="edgeLabel;html=1;fontSize=8;fontColor=#00897B;" vertex="1" connectable="0" parent="ef3">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ========== FULL GRAPH TOPOLOGY ========== -->
