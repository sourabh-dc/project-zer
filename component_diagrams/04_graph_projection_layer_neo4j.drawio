        <!-- ===== LEGEND ===== -->
        <mxCell id="grp_legend" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="620" y="520" width="320" height="110" as="geometry" />
        </mxCell>
        <mxCell id="leg_title" value="Entity → Event Handler Mapping" style="text;html=1;fontSize=10;fontStyle=5;align=center;verticalAlign=middle;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="650" y="523" width="260" height="18" as="geometry" />
        </mxCell>
        <mxCell id="leg_list" value="&lt;font style='font-size:8px;font-family:monospace'&gt;tenant.created → TenantHandler&lt;br&gt;site.created/updated → SiteHandler&lt;br&gt;store.created/updated → StoreHandler&lt;br&gt;org_unit.created/updated → OrgUnitHandler&lt;br&gt;user.created/updated → UserHandler&lt;br&gt;vendor/category/cost_centre → respective handlers&lt;br&gt;approved_range.* → ApprovedRangeHandler&lt;br&gt;store_product.* → StoreProductHandler&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="635" y="543" width="290" height="80" as="geometry" />
        </mxCell>

        <!-- Product filtering note -->
        <mxCell id="note_prod" value="&lt;font style='font-size:9px'&gt;&lt;b&gt;Note:&lt;/b&gt; product.created / product.updated events are &lt;b&gt;NOT handled&lt;/b&gt; by the graph consumer.&lt;br&gt;Products only appear in Neo4j via &lt;b&gt;approved_range.products_added&lt;/b&gt; events.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=9;arcSize=8;" vertex="1" parent="1">
