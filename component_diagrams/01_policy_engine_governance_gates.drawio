<mxfile host="app.diagrams.net" modified="2026-02-19T00:00:00.000Z" agent="cursor" version="24.0.0" type="device">
  <diagram id="policy-engine" name="Policy Engine &amp; Governance Gates">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="1 — Policy Engine &amp; Governance Gates" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="35" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Every write endpoint passes through two sequential authorization gates before business logic executes" style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="200" y="42" width="600" height="22" as="geometry" />
        </mxCell>

        <!-- ========== INCOMING REQUEST ========== -->
        <mxCell id="req" value="&lt;b&gt;Incoming HTTP Request&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;POST /provisioning/sites&lt;br&gt;Authorization: Bearer &amp;lt;JWT&amp;gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontSize=11;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="330" y="80" width="340" height="55" as="geometry" />
        </mxCell>

        <!-- ========== JWT DECODE ========== -->
        <mxCell id="jwt" value="&lt;b&gt;JWT Decode &amp; Verify&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Extract: user_id, tenant_id, roles[]&lt;br&gt;Verify signature with JWT_SECRET&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="170" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="req" target="jwt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== GATE 1 — RBAC ========== -->
        <mxCell id="grp_gate1" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;dashed=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="260" width="760" height="120" as="geometry" />
        </mxCell>
        <mxCell id="gate1_label" value="GATE 1 — Role-Based Access Control (RBAC)" style="text;html=1;fontSize=13;fontStyle=5;align=center;verticalAlign=middle;fontColor=#1565C0;" vertex="1" parent="1">
          <mxGeometry x="280" y="265" width="440" height="20" as="geometry" />
        </mxCell>

        <mxCell id="g1_check" value="&lt;b&gt;check_user_authorization&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Required permission passed as argument&lt;br&gt;e.g. &quot;sites.manage&quot;, &quot;catalog.manage&quot;&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565C0;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="290" width="220" height="75" as="geometry" />
        </mxCell>
        <mxCell id="g1_lookup" value="&lt;b&gt;DB Lookup&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;users → user_roles → roles&lt;br&gt;→ role_permissions → permissions&lt;br&gt;Match: user has required permission?&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565C0;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="290" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="g1_deny" value="&lt;b&gt;403 Forbidden&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Insufficient permissions&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="295" width="150" height="45" as="geometry" />
        </mxCell>

        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="jwt" target="g1_check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1565C0;strokeWidth=1.5;" edge="1" parent="1" source="g1_check" target="g1_lookup">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3l" value="lookup" style="edgeLabel;html=1;fontSize=8;fontColor=#1565C0;" vertex="1" connectable="0" parent="e3">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=1.5;dashed=1;" edge="1" parent="1" source="g1_lookup" target="g1_deny">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4l" value="no match" style="edgeLabel;html=1;fontSize=8;fontColor=#C62828;" vertex="1" connectable="0" parent="e4">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ========== GATE 2 — POLICY ENGINE ========== -->
        <mxCell id="grp_gate2" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#C62828;dashed=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="420" width="760" height="200" as="geometry" />
        </mxCell>
        <mxCell id="gate2_label" value="GATE 2 — Policy Engine (Separate HTTP Service · port 8004)" style="text;html=1;fontSize=13;fontStyle=5;align=center;verticalAlign=middle;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="220" y="425" width="560" height="20" as="geometry" />
        </mxCell>

        <!-- Provisioning side: require_policy -->
        <mxCell id="g2_require" value="&lt;b&gt;require_policy(action)&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;FastAPI Dependency&lt;br&gt;e.g. require_policy(&quot;site.create&quot;)&lt;br&gt;Extracts JWT, calls policy service&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C62828;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="455" width="200" height="65" as="geometry" />
        </mxCell>

        <!-- Circuit Breaker -->
        <mxCell id="g2_cb" value="&lt;b&gt;Circuit Breaker&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;CLOSED → normal&lt;br&gt;OPEN → deny all (fail-closed)&lt;br&gt;HALF_OPEN → probe one request&lt;br&gt;Threshold: 5 failures / 30s cooldown&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="140" y="535" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- HTTP call -->
        <mxCell id="g2_http" value="&lt;b&gt;HTTP POST&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;policy-engine:8004/evaluate&lt;br&gt;{action, resource, subject}&lt;br&gt;Timeout: 5s&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C62828;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="455" width="190" height="60" as="geometry" />
        </mxCell>

        <!-- Policy Service internals -->
        <mxCell id="g2_ctx" value="&lt;b&gt;Context Enricher&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Queries shared DB:&lt;br&gt;• user + roles + permissions&lt;br&gt;• tenant subscription + features&lt;br&gt;• budget (cost centre)&lt;br&gt;• approved_product_ids&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9C27B0;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="448" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="g2_eval" value="&lt;b&gt;Policy Evaluator&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;• Fetch matching policies by action&lt;br&gt;• Safe AST expression engine&lt;br&gt;• Evaluate conditions against context&lt;br&gt;• First match wins (priority order)&lt;br&gt;• No match → &lt;b&gt;DEFAULT DENY&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C62828;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="535" width="210" height="75" as="geometry" />
        </mxCell>

        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;exitX=0.5;exitY=1;" edge="1" parent="1" source="g1_lookup" target="g2_require">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5l" value="RBAC passed ✓" style="edgeLabel;html=1;fontSize=9;fontColor=#2E7D32;fontStyle=1;" vertex="1" connectable="0" parent="e5">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <mxCell id="e6" style="rounded=1;strokeColor=#C62828;strokeWidth=1.5;" edge="1" parent="1" source="g2_require" target="g2_http">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6cb" style="rounded=1;strokeColor=#E65100;strokeWidth=1;dashed=1;" edge="1" parent="1" source="g2_require" target="g2_cb">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="rounded=1;strokeColor=#C62828;strokeWidth=1.5;" edge="1" parent="1" source="g2_http" target="g2_ctx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="rounded=1;strokeColor=#9C27B0;strokeWidth=1.5;" edge="1" parent="1" source="g2_ctx" target="g2_eval">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Redis cache -->
        <mxCell id="redis" value="&lt;b&gt;Redis&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Context + Policy&lt;br&gt;cache (TTL)&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=9;size=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="460" width="60" height="55" as="geometry" />
        </mxCell>
        <mxCell id="e_redis" style="rounded=1;strokeColor=#E65100;strokeWidth=1;dashed=1;" edge="1" parent="1" source="g2_ctx" target="redis">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== OUTCOME ========== -->
        <mxCell id="allow" value="&lt;b&gt;✓ ALLOW&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Proceed to business logic&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="660" width="200" height="45" as="geometry" />
        </mxCell>
        <mxCell id="deny" value="&lt;b&gt;✗ DENY&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;403 — Policy violation&lt;br&gt;Reason logged to decision_log&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=11;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="550" y="660" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="g2_eval" target="allow">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9l" value="effect = allow" style="edgeLabel;html=1;fontSize=9;fontColor=#2E7D32;fontStyle=1;" vertex="1" connectable="0" parent="e9">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#C62828;strokeWidth=2;" edge="1" parent="1" source="g2_eval" target="deny">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10l" value="effect = deny / no match" style="edgeLabel;html=1;fontSize=9;fontColor=#C62828;fontStyle=1;" vertex="1" connectable="0" parent="e10">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ========== SAMPLE POLICIES ========== -->
        <mxCell id="grp_policies" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="120" y="740" width="760" height="100" as="geometry" />
        </mxCell>
        <mxCell id="pol_title" value="Example Seeded Governance Policies (10 rules)" style="text;html=1;fontSize=11;fontStyle=5;align=center;verticalAlign=middle;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="280" y="743" width="440" height="18" as="geometry" />
        </mxCell>
        <mxCell id="pol_list" value="&lt;font style='font-size:9px;font-family:monospace'&gt;• active_subscription_required — deny if no active subscription&lt;br&gt;• budget_limit_check — deny if order exceeds cost-centre budget&lt;br&gt;• approved_product_only — deny if product not in approved range&lt;br&gt;• tenant_admin_full_access — allow tenant_admin all actions&lt;br&gt;• store_manager_scope — allow store managers within their store&lt;br&gt;• max_sites_per_tenant — limit site count by subscription tier&lt;br&gt;• category_management — restrict category operations to admins&lt;br&gt;• vendor_management — restrict vendor operations to procurement roles&lt;br&gt;• product_creation_limit — enforce product count limits per plan&lt;br&gt;• cost_centre_budget_enforcement — enforce spending limits&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="140" y="764" width="720" height="70" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
