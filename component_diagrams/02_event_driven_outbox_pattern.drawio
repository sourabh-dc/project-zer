<mxfile host="app.diagrams.net" modified="2026-02-19T00:00:00.000Z" agent="cursor" version="24.0.0" type="device">
  <diagram id="event-driven" name="Event-Driven Architecture (Outbox Pattern)">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="2 — Event-Driven Architecture (Transactional Outbox Pattern)" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="180" y="10" width="640" height="35" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Business write + outbox event committed atomically in a single DB transaction. Consumers poll and project to downstream stores." style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="150" y="42" width="700" height="22" as="geometry" />
        </mxCell>

        <!-- ========== WRITE OPERATION ========== -->
        <mxCell id="api" value="&lt;b&gt;API Write Endpoint&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;e.g. POST /provisioning/sites&lt;br&gt;After RBAC + Policy gates pass&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontSize=11;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="350" y="80" width="300" height="55" as="geometry" />
        </mxCell>

        <!-- ========== SINGLE TRANSACTION BOX ========== -->
        <mxCell id="grp_tx" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=3;dashed=0;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="170" width="760" height="200" as="geometry" />
        </mxCell>
        <mxCell id="tx_label" value="Single PostgreSQL Transaction (ACID)" style="text;html=1;fontSize=14;fontStyle=5;align=center;verticalAlign=middle;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="300" y="175" width="400" height="22" as="geometry" />
        </mxCell>

        <!-- Business table write -->
        <mxCell id="biz_write" value="&lt;b&gt;Step 1: Business Write&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;INSERT / UPDATE entity in its table&lt;br&gt;e.g. INSERT INTO sites (...)&lt;br&gt;or UPDATE products SET status='deleted'&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="150" y="210" width="300" height="65" as="geometry" />
        </mxCell>

        <!-- Outbox write -->
        <mxCell id="outbox_write" value="&lt;b&gt;Step 2: Outbox Event&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;INSERT INTO outbox_events&lt;br&gt;(event_type, aggregate_type,&lt;br&gt; aggregate_id, tenant_id, payload)&lt;br&gt;&lt;b&gt;Same transaction as Step 1&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="530" y="205" width="300" height="75" as="geometry" />
        </mxCell>

        <mxCell id="e_bw" style="rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="biz_write" target="outbox_write">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_bwl" value="same TX" style="edgeLabel;html=1;fontSize=9;fontColor=#2E7D32;fontStyle=1;" vertex="1" connectable="0" parent="e_bw">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- DB commit -->
        <mxCell id="commit" value="&lt;b&gt;db.commit()&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Both entity + event are durable&lt;br&gt;or neither is (atomicity)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="300" width="300" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e_com1" style="rounded=1;strokeColor=#2E7D32;strokeWidth=1.5;" edge="1" parent="1" source="biz_write" target="commit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_com2" style="rounded=1;strokeColor=#F9A825;strokeWidth=1.5;" edge="1" parent="1" source="outbox_write" target="commit">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="e_api_tx" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="api" target="grp_tx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== OUTBOX TABLE ========== -->
        <mxCell id="outbox_tbl" value="&lt;b&gt;outbox_events table&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;id | event_type | aggregate_type&lt;br&gt;aggregate_id | tenant_id | payload&lt;br&gt;status (pending→processed) | created_at&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;size=12;" vertex="1" parent="1">
          <mxGeometry x="380" y="410" width="240" height="85" as="geometry" />
        </mxCell>

        <mxCell id="e_ctx" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#F9A825;strokeWidth=2;" edge="1" parent="1" source="commit" target="outbox_tbl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== CONSUMERS ========== -->
        <mxCell id="grp_consumers" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F57F17;dashed=1;dashPattern=5 5;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="540" width="840" height="140" as="geometry" />
        </mxCell>
        <mxCell id="cons_title" value="Outbox Consumers (Background Pollers — each service polls independently)" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#F57F17;" vertex="1" parent="1">
          <mxGeometry x="200" y="545" width="600" height="20" as="geometry" />
        </mxCell>

        <mxCell id="cons_graph" value="&lt;b&gt;Graph Consumer&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Polls outbox_events&lt;br&gt;Routes by event_type to handler&lt;br&gt;e.g. site.created → SiteHandler&lt;br&gt;Writes Cypher MERGE to Neo4j&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="575" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="cons_vector" value="&lt;b&gt;Vector Consumer&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Polls outbox_events&lt;br&gt;Filters: product.* events only&lt;br&gt;Generates embedding via Azure OpenAI&lt;br&gt;Upserts into pgvector&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="390" y="575" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="cons_future" value="&lt;b&gt;Future Consumers&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Audit log, notifications,&lt;br&gt;analytics, webhooks...&lt;br&gt;All subscribe to same outbox&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#607D8B;fontSize=9;arcSize=10;dashed=1;dashPattern=5 5;" vertex="1" parent="1">
          <mxGeometry x="680" y="575" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e_poll1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#00897B;strokeWidth=2;" edge="1" parent="1" source="outbox_tbl" target="cons_graph">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_poll1l" value="poll" style="edgeLabel;html=1;fontSize=8;fontColor=#00897B;" vertex="1" connectable="0" parent="e_poll1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="e_poll2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#7B1FA2;strokeWidth=2;" edge="1" parent="1" source="outbox_tbl" target="cons_vector">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_poll2l" value="poll" style="edgeLabel;html=1;fontSize=8;fontColor=#7B1FA2;" vertex="1" connectable="0" parent="e_poll2">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="e_poll3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#607D8B;strokeWidth=1.5;dashed=1;" edge="1" parent="1" source="outbox_tbl" target="cons_future">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== DOWNSTREAM STORES ========== -->
        <mxCell id="neo4j" value="&lt;b&gt;Neo4j&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Graph Topology&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#00897B;fontColor=#ffffff;strokeColor=#00897B;fontSize=10;size=10;" vertex="1" parent="1">
          <mxGeometry x="145" y="720" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="pgvec" value="&lt;b&gt;pgvector&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Embeddings&lt;/font&gt;" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#7B1FA2;fontColor=#ffffff;strokeColor=#7B1FA2;fontSize=10;size=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="720" width="120" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e_n" style="rounded=1;strokeColor=#00897B;strokeWidth=2;" edge="1" parent="1" source="cons_graph" target="neo4j">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_v" style="rounded=1;strokeColor=#7B1FA2;strokeWidth=2;" edge="1" parent="1" source="cons_vector" target="pgvec">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== KEY PROPERTIES ========== -->
        <mxCell id="grp_props" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="630" y="710" width="290" height="140" as="geometry" />
        </mxCell>
        <mxCell id="props_title" value="Key Properties" style="text;html=1;fontSize=11;fontStyle=5;align=center;verticalAlign=middle;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="640" y="715" width="270" height="18" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="&lt;font style='font-size:9px'&gt;✓ &lt;b&gt;Atomicity&lt;/b&gt; — event + entity in same TX&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="645" y="738" width="260" height="18" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="&lt;font style='font-size:9px'&gt;✓ &lt;b&gt;At-least-once&lt;/b&gt; — consumer marks processed&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="645" y="758" width="260" height="18" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="&lt;font style='font-size:9px'&gt;✓ &lt;b&gt;Rebuildable&lt;/b&gt; — projections from event log&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="645" y="778" width="260" height="18" as="geometry" />
        </mxCell>
        <mxCell id="p4" value="&lt;font style='font-size:9px'&gt;✓ &lt;b&gt;Decoupled&lt;/b&gt; — new consumers without code change&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="645" y="798" width="270" height="18" as="geometry" />
        </mxCell>
        <mxCell id="p5" value="&lt;font style='font-size:9px'&gt;✓ &lt;b&gt;No message broker needed&lt;/b&gt; — DB-native polling&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="645" y="818" width="270" height="18" as="geometry" />
        </mxCell>

        <!-- ========== EVENT TYPES COLUMN ========== -->
        <mxCell id="grp_evt" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="80" y="810" width="500" height="90" as="geometry" />
        </mxCell>
        <mxCell id="evt_title" value="Event Types Emitted" style="text;html=1;fontSize=10;fontStyle=5;align=center;verticalAlign=middle;fontColor=#F57F17;" vertex="1" parent="1">
          <mxGeometry x="250" y="812" width="160" height="18" as="geometry" />
        </mxCell>
        <mxCell id="evt_list" value="&lt;font style='font-size:8px;font-family:monospace'&gt;tenant.created · site.created/updated · store.created/updated · org_unit.created/updated · user.created/updated&lt;br&gt;vendor.created/updated · category.created/updated · product.created/updated · cost_centre.created · role.created/updated&lt;br&gt;approved_range.created · approved_range.products_added · approved_range.products_removed · policy.created/updated · *.deleted&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="90" y="833" width="480" height="60" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
