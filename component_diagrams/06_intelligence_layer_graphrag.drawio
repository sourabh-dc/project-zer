<mxfile host="app.diagrams.net" modified="2026-02-19T00:00:00.000Z" agent="cursor" version="24.0.0" type="device">
  <diagram id="intelligence-layer" name="Intelligence Layer (GraphRAG)">
    <mxGraphModel dx="1800" dy="1500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="6 — Intelligence Layer (GraphRAG)" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="250" y="10" width="500" height="35" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="Natural language questions are classified by an LLM, routed to the right backend(s), executed, and summarized back into natural language" style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="120" y="42" width="760" height="22" as="geometry" />
        </mxCell>

        <!-- ========== USER QUESTION ========== -->
        <mxCell id="user_q" value="&lt;b&gt;Admin / User&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;&quot;What products are in the Q1 approved range?&quot;&lt;br&gt;&quot;Which users spent more than 50k last month?&quot;&lt;br&gt;&quot;Find products similar to blue disposable gloves&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;fontColor=#ffffff;strokeColor=#1a1a2e;fontSize=10;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="80" width="400" height="65" as="geometry" />
        </mxCell>

        <!-- ========== INTELLIGENCE SERVICE ========== -->
        <mxCell id="grp_intel" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9B59B6;arcSize=6;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="175" width="880" height="360" as="geometry" />
        </mxCell>
        <mxCell id="intel_title" value="Intelligence Service (port 8005)" style="text;html=1;fontSize=14;fontStyle=5;align=center;verticalAlign=middle;fontColor=#9B59B6;" vertex="1" parent="1">
          <mxGeometry x="330" y="180" width="340" height="22" as="geometry" />
        </mxCell>

        <!-- Step 1: LLM Classification -->
        <mxCell id="s1_llm" value="&lt;b&gt;Step 1: LLM Classification&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Azure OpenAI &lt;b&gt;gpt-5-nano&lt;/b&gt;&lt;br&gt;System prompt with schema descriptions&lt;br&gt;(Postgres tables + Neo4j node types)&lt;br&gt;Classifies: graph / sql / vector / hybrid&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="210" width="260" height="80" as="geometry" />
        </mxCell>

        <!-- LLM output: query plan -->
        <mxCell id="s1_plan" value="&lt;b&gt;Query Plan (JSON)&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:8px;font-family:monospace'&gt;{&lt;br&gt;  &quot;query_type&quot;: &quot;graph&quot;,&lt;br&gt;  &quot;steps&quot;: [&lt;br&gt;    { &quot;engine&quot;: &quot;graph&quot;,&lt;br&gt;      &quot;query&quot;: &quot;MATCH (ar)...&quot; }&lt;br&gt;  ]&lt;br&gt;}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9B59B6;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="650" y="210" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="e_uq" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=2;" edge="1" parent="1" source="user_q" target="s1_llm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_uql" value="POST /intelligence/query" style="edgeLabel;html=1;fontSize=8;fontColor=#666;" vertex="1" connectable="0" parent="e_uq">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="e_lp" style="rounded=1;strokeColor=#9B59B6;strokeWidth=2;" edge="1" parent="1" source="s1_llm" target="s1_plan">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_lpl" value="JSON response" style="edgeLabel;html=1;fontSize=8;fontColor=#9B59B6;" vertex="1" connectable="0" parent="e_lp">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- Step 2: Query Router fans out -->
        <mxCell id="s2_router" value="&lt;b&gt;Step 2: Query Router&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Executes each step in the plan&lt;br&gt;Respects step dependencies&lt;br&gt;All queries are &lt;b&gt;READ-ONLY&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9B59B6;fontSize=10;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="200" height="65" as="geometry" />
        </mxCell>

        <mxCell id="e_pr" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9B59B6;strokeWidth=2;" edge="1" parent="1" source="s1_plan" target="s2_router">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Three backends -->
        <mxCell id="be_sql" value="&lt;b&gt;SQL Engine&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;PostgreSQL (read-only)&lt;br&gt;Exact counts, sums, dates&lt;br&gt;Budget analysis, spending&lt;br&gt;Parameterized: :tenant_id&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#0078D4;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="330" width="180" height="75" as="geometry" />
        </mxCell>
        <mxCell id="be_graph" value="&lt;b&gt;Graph Engine&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Neo4j (read-only Cypher)&lt;br&gt;Relationships, hierarchy&lt;br&gt;Approved ranges, org topology&lt;br&gt;Parameterized: $tenant_id&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="330" width="180" height="75" as="geometry" />
        </mxCell>
        <mxCell id="be_vector" value="&lt;b&gt;Vector Engine&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;pgvector (similarity search)&lt;br&gt;Fuzzy text / product search&lt;br&gt;Cosine similarity, Top-K&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="770" y="330" width="150" height="75" as="geometry" />
        </mxCell>

        <mxCell id="er1" style="rounded=1;strokeColor=#0078D4;strokeWidth=1.5;" edge="1" parent="1" source="s2_router" target="be_sql">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="er1l" value="sql" style="edgeLabel;html=1;fontSize=8;fontColor=#0078D4;fontStyle=1;" vertex="1" connectable="0" parent="er1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="er2" style="rounded=1;strokeColor=#00897B;strokeWidth=1.5;" edge="1" parent="1" source="s2_router" target="be_graph">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="er2l" value="graph" style="edgeLabel;html=1;fontSize=8;fontColor=#00897B;fontStyle=1;" vertex="1" connectable="0" parent="er2">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="er3" style="rounded=1;strokeColor=#7B1FA2;strokeWidth=1.5;" edge="1" parent="1" source="s2_router" target="be_vector">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="er3l" value="vector" style="edgeLabel;html=1;fontSize=8;fontColor=#7B1FA2;fontStyle=1;" vertex="1" connectable="0" parent="er3">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- Step 3: Summarizer -->
        <mxCell id="s3_summ" value="&lt;b&gt;Step 3: LLM Summarizer&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Combines raw results from all engines&lt;br&gt;Generates natural language answer&lt;br&gt;gpt-5-nano with context window&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="450" width="240" height="65" as="geometry" />
        </mxCell>

        <mxCell id="er4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="be_sql" target="s3_summ">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="er5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="be_graph" target="s3_summ">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="er6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=1.5;" edge="1" parent="1" source="be_vector" target="s3_summ">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== RESPONSE ========== -->
        <mxCell id="response" value="&lt;b&gt;Natural Language Answer&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;&quot;The Q1 Approved Range contains 5 products:&lt;br&gt;Blue Disposable Gloves, Safety Goggles, ...&lt;br&gt;These are available to the Procurement org unit.&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=10;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="250" y="570" width="500" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e_resp" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="s3_summ" target="response">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== QUERY TYPE EXAMPLES ========== -->
        <mxCell id="grp_examples" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="660" width="880" height="165" as="geometry" />
        </mxCell>
        <mxCell id="ex_title" value="Query Type Examples &amp; Routing" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="350" y="663" width="300" height="20" as="geometry" />
        </mxCell>

        <mxCell id="ex_sql" value="&lt;font color='#0078D4'&gt;&lt;b&gt;SQL Queries&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;• &quot;How many users do we have?&quot;&lt;br&gt;• &quot;What's our total spending this month?&quot;&lt;br&gt;• &quot;List vendors created after Jan 2026&quot;&lt;br&gt;• &quot;Which cost centres exceeded budget?&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#0078D4;fontSize=9;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="690" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ex_graph" value="&lt;font color='#00897B'&gt;&lt;b&gt;Graph Queries&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;• &quot;What products are in Q1 range?&quot;&lt;br&gt;• &quot;Which stores are in the London site?&quot;&lt;br&gt;• &quot;What org units use range X?&quot;&lt;br&gt;• &quot;Show the governance hierarchy&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2F1;strokeColor=#00897B;fontSize=9;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="370" y="690" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ex_hybrid" value="&lt;font color='#9B59B6'&gt;&lt;b&gt;Hybrid / Vector Queries&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;• &quot;Find PPE products&quot; (vector)&lt;br&gt;• &quot;Users in Mumbai who spent &amp;gt;50k&quot;&lt;br&gt;  (graph for Mumbai + SQL for spending)&lt;br&gt;• &quot;Similar to blue gloves in budget?&quot;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9B59B6;fontSize=9;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="660" y="690" width="250" height="80" as="geometry" />
        </mxCell>

        <!-- ========== SAFETY RULES ========== -->
        <mxCell id="grp_safety" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="850" width="880" height="65" as="geometry" />
        </mxCell>
        <mxCell id="safety_title" value="Safety Constraints" style="text;html=1;fontSize=11;fontStyle=5;align=center;verticalAlign=middle;fontColor=#C62828;" vertex="1" parent="1">
          <mxGeometry x="400" y="853" width="200" height="18" as="geometry" />
        </mxCell>
        <mxCell id="safety_list" value="&lt;font style='font-size:9px'&gt;• &lt;b&gt;SQL: SELECT only&lt;/b&gt; — never INSERT/UPDATE/DELETE   • &lt;b&gt;Cypher: MATCH/RETURN only&lt;/b&gt; — never CREATE/DELETE/SET/MERGE   • &lt;b&gt;Always tenant-scoped&lt;/b&gt; — parameterized :tenant_id / $tenant_id   • &lt;b&gt;Response format: JSON&lt;/b&gt; — structured for parsing&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="873" width="840" height="35" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
