<mxfile host="app.diagrams.net" modified="2026-02-19T00:00:00.000Z" agent="cursor" version="24.0.0" type="device">
  <diagram id="tenant-onboarding" name="Tenant Onboarding &amp; Subscription Lifecycle">
    <mxGraphModel dx="1800" dy="1500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="1400" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- TITLE -->
        <mxCell id="title" value="7 — Tenant Onboarding &amp; Subscription Lifecycle" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="200" y="10" width="600" height="35" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="The only flow exempt from policy gates. Creates tenant, admin user, default roles, then subscription activates feature entitlements." style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="120" y="42" width="760" height="22" as="geometry" />
        </mxCell>

        <!-- ========== OTP FLOW ========== -->
        <mxCell id="grp_otp" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="880" height="100" as="geometry" />
        </mxCell>
        <mxCell id="otp_title" value="Step 1: Email OTP Verification (No Auth Required)" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#3F51B5;" vertex="1" parent="1">
          <mxGeometry x="260" y="83" width="480" height="20" as="geometry" />
        </mxCell>

        <mxCell id="otp_gen" value="&lt;b&gt;POST /onboarding/otp/generate&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Input: email address&lt;br&gt;Generates 6-digit OTP&lt;br&gt;Sends via Azure Email Service&lt;br&gt;Stores hash in memory (5min TTL)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#3F51B5;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="108" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="otp_val" value="&lt;b&gt;POST /onboarding/otp/validate&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Input: email + OTP code&lt;br&gt;Verifies hash match&lt;br&gt;Max 3 attempts&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#3F51B5;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="108" width="190" height="60" as="geometry" />
        </mxCell>
        <mxCell id="otp_ok" value="&lt;b&gt;OTP Verified&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Email is trusted&lt;br&gt;Proceed to signup&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="630" y="112" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="eo1" style="rounded=1;strokeColor=#3F51B5;strokeWidth=2;" edge="1" parent="1" source="otp_gen" target="otp_val">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eo2" style="rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="otp_val" target="otp_ok">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ========== TENANT SIGNUP ========== -->
        <mxCell id="grp_signup" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;arcSize=8;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="210" width="880" height="170" as="geometry" />
        </mxCell>
        <mxCell id="signup_title" value="Step 2: Tenant Signup (EXEMPT from Policy Gate)" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="260" y="213" width="480" height="20" as="geometry" />
        </mxCell>

        <mxCell id="su_api" value="&lt;b&gt;POST /onboarding/tenant-signup&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Input: tenant_name, tenant_type,&lt;br&gt;admin email, password, first/last name&lt;br&gt;&lt;b&gt;No JWT required&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#E65100;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="245" width="210" height="65" as="geometry" />
        </mxCell>

        <mxCell id="su_creates" value="&lt;b&gt;Atomic Transaction Creates:&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;1. Tenant record&lt;br&gt;2. Admin User (bcrypt password)&lt;br&gt;3. Default Role: &quot;tenant_admin&quot;&lt;br&gt;4. User ↔ Role assignment&lt;br&gt;5. Default permissions for admin role&lt;br&gt;6. Outbox: tenant.created + user.created&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="240" width="250" height="95" as="geometry" />
        </mxCell>

        <mxCell id="su_jwt" value="&lt;b&gt;Response&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;JWT token (tenant_id, user_id,&lt;br&gt;roles: [tenant_admin])&lt;br&gt;+ Refresh token&lt;br&gt;Admin is now logged in&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="680" y="245" width="200" height="65" as="geometry" />
        </mxCell>

        <mxCell id="es1" style="rounded=1;strokeColor=#E65100;strokeWidth=2;" edge="1" parent="1" source="su_api" target="su_creates">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="es2" style="rounded=1;strokeColor=#2E7D32;strokeWidth=2;" edge="1" parent="1" source="su_creates" target="su_jwt">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="exempt_note" value="&lt;font style='font-size:9px' color='#C62828'&gt;&lt;b&gt;Why exempt?&lt;/b&gt; No tenant exists yet → no policies to evaluate.&lt;br&gt;This is the only endpoint that bypasses both RBAC and Policy gates.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCDD2;strokeColor=#C62828;fontSize=9;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="348" width="450" height="28" as="geometry" />
        </mxCell>

        <!-- ========== LOGIN ========== -->
        <mxCell id="grp_login" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#607D8B;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="410" width="880" height="85" as="geometry" />
        </mxCell>
        <mxCell id="login_title" value="Step 3: Login (Also No Policy Gate)" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#607D8B;" vertex="1" parent="1">
          <mxGeometry x="310" y="413" width="380" height="20" as="geometry" />
        </mxCell>
        <mxCell id="login_flow" value="&lt;b&gt;POST /onboarding/login&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;email + password → bcrypt verify → JWT issued&lt;br&gt;JWT contains: user_id, tenant_id, roles[], permissions[]&lt;br&gt;All subsequent API calls use this JWT in Authorization header&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#607D8B;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="438" width="840" height="48" as="geometry" />
        </mxCell>

        <!-- ========== SUBSCRIPTION ========== -->
        <mxCell id="grp_sub" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;arcSize=8;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="525" width="880" height="195" as="geometry" />
        </mxCell>
        <mxCell id="sub_title" value="Step 4: Subscription &amp; Feature Entitlements (Policy-Gated from here)" style="text;html=1;fontSize=12;fontStyle=5;align=center;verticalAlign=middle;fontColor=#2E7D32;" vertex="1" parent="1">
          <mxGeometry x="200" y="528" width="600" height="20" as="geometry" />
        </mxCell>

        <mxCell id="sub_plans" value="&lt;b&gt;Subscription Plans&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;starter / professional / enterprise&lt;br&gt;Each plan has:&lt;br&gt;• Monthly / Quarterly / Yearly pricing&lt;br&gt;• Feature set with limits&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="555" width="200" height="75" as="geometry" />
        </mxCell>

        <mxCell id="sub_features" value="&lt;b&gt;Feature Entitlements&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;sites.manage (max: 5)&lt;br&gt;stores.manage (max: 20)&lt;br&gt;products (max: 1000)&lt;br&gt;vendors.manage (max: 50)&lt;br&gt;cost_centres (max: 10)&lt;br&gt;categories (max: 100)&lt;br&gt;approved_ranges (max: 10)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#FF9800;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="555" width="190" height="100" as="geometry" />
        </mxCell>

        <mxCell id="sub_check" value="&lt;b&gt;check_feature_limit()&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Called on every write endpoint&lt;br&gt;Checks current usage vs plan limit&lt;br&gt;If exceeded → &lt;b&gt;HTTP 429&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;b&gt;record_feature_usage()&lt;/b&gt;&lt;br&gt;Increments counter after success&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#C62828;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="590" y="555" width="200" height="100" as="geometry" />
        </mxCell>

        <mxCell id="sub_stripe" value="&lt;b&gt;Stripe Integration&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Checkout sessions&lt;br&gt;Webhook confirmation&lt;br&gt;Subscription activation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#0078D4;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="650" width="160" height="55" as="geometry" />
        </mxCell>

        <mxCell id="sub_trial" value="&lt;b&gt;Trial Period&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;7-day free trial&lt;br&gt;Full feature access&lt;br&gt;is_trial = true&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=9;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="665" width="150" height="45" as="geometry" />
        </mxCell>

        <mxCell id="esub1" style="rounded=1;strokeColor=#FF9800;strokeWidth=1.5;" edge="1" parent="1" source="sub_plans" target="sub_features">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="esub1l" value="plan_features" style="edgeLabel;html=1;fontSize=8;fontColor=#FF9800;" vertex="1" connectable="0" parent="esub1">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>
        <mxCell id="esub2" style="rounded=1;strokeColor=#C62828;strokeWidth=1.5;" edge="1" parent="1" source="sub_features" target="sub_check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="esub2l" value="enforced on every write" style="edgeLabel;html=1;fontSize=8;fontColor=#C62828;" vertex="1" connectable="0" parent="esub2">
          <mxGeometry relative="1" as="geometry"><mxPoint as="offset" /></mxGeometry>
        </mxCell>

        <!-- ========== FULL TIMELINE ========== -->
        <mxCell id="grp_timeline" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#BDBDBD;arcSize=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="750" width="880" height="70" as="geometry" />
        </mxCell>
        <mxCell id="tl_title" value="Complete Onboarding Timeline" style="text;html=1;fontSize=11;fontStyle=5;align=center;verticalAlign=middle;fontColor=#333;" vertex="1" parent="1">
          <mxGeometry x="330" y="753" width="340" height="18" as="geometry" />
        </mxCell>
        <mxCell id="tl" value="&lt;font style='font-size:10px'&gt;&lt;b&gt;OTP Verify&lt;/b&gt; → &lt;b&gt;Tenant Signup&lt;/b&gt; (creates tenant + admin + roles) → &lt;b&gt;Login&lt;/b&gt; (get JWT) → &lt;b&gt;Subscribe&lt;/b&gt; (activate plan) → &lt;b&gt;Provision&lt;/b&gt; (create sites, stores, users — now policy-gated)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="80" y="773" width="840" height="40" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
