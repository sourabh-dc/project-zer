        </mxCell>
        <mxCell id="subtitle" value="From financial calendar &amp; cost centre setup → order creation → self-approval or multi-stage approval → PO to vendor. Budget vs approval limits distinguished." style="text;html=1;fontSize=11;fontStyle=2;align=center;verticalAlign=middle;whiteSpace=wrap;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="120" y="45" width="960" height="22" as="geometry" />
