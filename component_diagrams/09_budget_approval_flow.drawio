          <mxGeometry x="290" y="125" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="a_cc" value="&lt;b&gt;Define Cost Centres&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Name, code, GL mapping&lt;br&gt;Active in 1+ years&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565C0;fontSize=10;arcSize=10;" vertex="1" parent="1">
