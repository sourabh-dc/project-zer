        <mxCell id="a_cal" value="&lt;b&gt;Define Financial Calendars&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:9px'&gt;Name, type (Gregorian, 4-4-5, custom)&lt;br&gt;Start/end dates, periods&lt;br&gt;Carry-forward rules&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565C0;fontSize=10;arcSize=10;" vertex="1" parent="1">
