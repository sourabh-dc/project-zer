        <mxCell id="10" value="Customer Journey" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="30" y="40" width="2050" height="180" as="geometry"/></mxCell>
        <mxCell id="11" value="1. Customer places order" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="70" y="100" width="170" height="60" as="geometry"/></mxCell>
