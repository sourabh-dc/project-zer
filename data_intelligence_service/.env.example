# ─── Data Intelligence Service — Environment Variables ────────────────────────
# Copy this file to .env and fill in the values.
# For deployed environments, these are fetched from Azure Key Vault automatically.
# ─────────────────────────────────────────────────────────────────────────────

ENVIRONMENT=local   # local | staging | production

# ─── Azure OpenAI ─────────────────────────────────────────────────────────────
# The LLM powering the query planner and summarizer.
# Reasoning models (gpt-5-nano, o1, o3): do NOT set temperature — they use default.
AZURE_OPENAI_API_KEY=your-azure-openai-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-06-01
AZURE_OPENAI_LLM_DEPLOYMENT=gpt-5-nano            # deployment name in Azure Portal
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Shared database — also used by provisioning_service and orders_service.
# The intelligence service only runs SELECT queries (read-only role recommended).
POSTGRES_HOST=localhost
POSTGRES_DB=zeroque
POSTGRES_USER=zeroque_user
POSTGRES_PASSWORD=your-postgres-password

# ─── Neo4j ────────────────────────────────────────────────────────────────────
# Graph database for governance topology, org hierarchy, approved ranges.
# Falls back to a static schema description if unreachable (safe for local dev).
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_DATABASE=neo4j

# ─── Intelligence API ─────────────────────────────────────────────────────────
# API key required in the X-API-Key header for /intelligence/* endpoints.
# Leave empty to disable auth (local dev only — never do this in production).
INTELLIGENCE_API_KEY=your-secret-api-key

# ─── Observability ────────────────────────────────────────────────────────────
# LangSmith — deep tracing for LangGraph agent runs (dev/staging).
# Set these to enable automatic tracing of all agent invocations.
LANGSMITH_API_KEY=                          # optional
LANGCHAIN_TRACING_V2=false                  # set to "true" when LANGSMITH_API_KEY is set
LANGCHAIN_PROJECT=zeroque-intelligence      # project name in LangSmith UI

# Langfuse — OTel-native trace backend for production (Sprint 1).
# LANGFUSE_SECRET_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com  # or your self-hosted URL

# ─── Tuning ───────────────────────────────────────────────────────────────────
VECTOR_SIMILARITY_THRESHOLD=0.30    # min cosine similarity to include a vector result
SQL_MAX_ROWS=500                    # max rows returned per SQL query (prevents data dumps)
CYPHER_MAX_ROWS=500
POLL_INTERVAL_SECONDS=2             # outbox consumer poll frequency
POLL_BATCH_SIZE=50                  # events claimed per poll cycle
LLM_MAX_RETRIES=3
LOG_LEVEL=INFO

# ─── Azure Key Vault (non-local only) ────────────────────────────────────────
# When ENVIRONMENT != "local", secrets are fetched from Key Vault instead.
# The service uses DefaultAzureCredential (managed identity in production).
# KEYVAULT_NAME=your-keyvault-name
